{
  "expo": {
    "name": "풀카운트_test",
    "slug": "fullcount-kr",
    "version": "1.1.8",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "fullcount",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fde8d6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "kr.fullcount.app.test",
      "buildNumber": "3",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "직관일기 작성 시 사진을 첨부하기 위해 앨범 접근 권한이 필요합니다.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "allowBackup": false,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fde8d6"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "package": "kr.fullcount.app.test",
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ],
      "versionCode": 28
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      ["react-native-android-widget", {
        "widgets": [{
          "name": "LiveScoreWidget",
          "label": "풀카운트 전광판",
          "description": "실시간 야구 점수를 홈 화면에서 확인하세요",
          "minWidth": "250dp",
          "minHeight": "110dp",
          "maxResizeWidth": "400dp",
          "maxResizeHeight": "200dp",
          "resizeMode": "horizontal|vertical",
          "targetCellWidth": 4,
          "targetCellHeight": 2,
          "updatePeriodMillis": 0
        }]
      }],
      "expo-router"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "61b58472-e18f-48c4-8471-fa6fa4294c42"
      }
    },
    "owner": "duboo82",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/61b58472-e18f-48c4-8471-fa6fa4294c42"
    }
  }
}
