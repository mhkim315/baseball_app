{
  "expo": {
    "name": "풀카운트",
    "slug": "fullcount-kr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "fullcount",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fde8d6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "kr.fullcount.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fde8d6"
      },
      "edgeToEdgeEnabled": true,
      "package": "kr.fullcount.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fb67090c-c448-49ae-b07a-73203a69fd9c"
      }
    },
    "owner": "minani"
  }
}
