{
  "expo": {
    "name": "풀카운트_test",
    "slug": "fullcount-kr",
    "version": "1.1.8",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "fullcount",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fde8d6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "kr.fullcount.app.test",
      "buildNumber": "3",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "직관일기 작성 시 사진을 첨부하기 위해 앨범 접근 권한이 필요합니다.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "allowBackup": false,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fde8d6"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "package": "kr.fullcount.app.test",
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ],
      "versionCode": 28
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      ["react-native-android-widget", {
        "widgets": [
          {
            "name": "MiniScoreWidget",
            "label": "풀카운트 미니",
            "description": "간단한 점수 확인용",
            "minWidth": "110dp",
            "minHeight": "40dp",
            "maxResizeWidth": "200dp",
            "maxResizeHeight": "100dp",
            "resizeMode": "horizontal|vertical",
            "targetCellWidth": 2,
            "targetCellHeight": 1,
            "updatePeriodMillis": 0
          },
          {
            "name": "ScoreWidget",
            "label": "풀카운트 소형",
            "description": "점수 + 상태 표시",
            "minWidth": "110dp",
            "minHeight": "110dp",
            "maxResizeWidth": "250dp",
            "maxResizeHeight": "180dp",
            "resizeMode": "horizontal|vertical",
            "targetCellWidth": 2,
            "targetCellHeight": 2,
            "updatePeriodMillis": 0
          },
          {
            "name": "LiveScoreWidget",
            "label": "풀카운트 전광판",
            "description": "실시간 야구 점수를 홈 화면에서 확인하세요",
            "minWidth": "250dp",
            "minHeight": "110dp",
            "maxResizeWidth": "500dp",
            "maxResizeHeight": "300dp",
            "resizeMode": "horizontal|vertical",
            "targetCellWidth": 4,
            "targetCellHeight": 2,
            "updatePeriodMillis": 0
          },
          {
            "name": "WideScoreWidget",
            "label": "풀카운트 와이드",
            "description": "넓은 화면에 풀 정보",
            "minWidth": "300dp",
            "minHeight": "110dp",
            "maxResizeWidth": "600dp",
            "maxResizeHeight": "300dp",
            "resizeMode": "horizontal|vertical",
            "targetCellWidth": 5,
            "targetCellHeight": 2,
            "updatePeriodMillis": 0
          },
          {
            "name": "DetailScoreWidget",
            "label": "풀카운트 상세",
            "description": "상세 정보 포함",
            "minWidth": "250dp",
            "minHeight": "180dp",
            "maxResizeWidth": "500dp",
            "maxResizeHeight": "400dp",
            "resizeMode": "horizontal|vertical",
            "targetCellWidth": 4,
            "targetCellHeight": 3,
            "updatePeriodMillis": 0
          }
        ]
      }],
      "expo-router"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "61b58472-e18f-48c4-8471-fa6fa4294c42"
      }
    },
    "owner": "duboo82",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/61b58472-e18f-48c4-8471-fa6fa4294c42"
    }
  }
}
