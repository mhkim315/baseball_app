{
  "expo": {
    "name": "풀카운트",
    "slug": "fullcount-kr",
    "version": "1.0.10",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "fullcount",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fde8d6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "kr.fullcount.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "직관일기 작성 시 사진을 첨부하기 위해 앨범 접근 권한이 필요합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fde8d6"
      },
      "edgeToEdgeEnabled": true,
      "package": "kr.fullcount.app",
      "versionCode": 11
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a8be0198-acf3-4625-92c2-f12f2d47ed53"
      }
    },
    "owner": "naninanimi"
  }
}
